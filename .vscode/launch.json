{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "fluvilog (collect)",
      "type": "debugpy",
      "request": "launch",
      "module": "fluvilog",
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "fluvilog (once)",
      "type": "debugpy",
      "request": "launch",
      "module": "fluvilog",
      "args": ["once", "--station", "BL"],
      "python": "${workspaceFolder}/.venv/bin/python",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
